									"var jsonData = pm.response.json();",
									"if (jsonData.success && jsonData.data && jsonData.data.id) {",
									"    pm.collectionVariables.set(\"merchantId\", jsonData.data.id);",
									"    pm.collectionVariables.set(\"merchantCode\", jsonData.data.merchantCode);",
									"    console.log(\"Saved merchantId: \" + jsonData.data.id + \", merchantCode: \" + jsonData.data.merchantCode);",
									"}"
								],
								"type": "text/javascript"
