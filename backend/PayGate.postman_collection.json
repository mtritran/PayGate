{
	"info": {
		"_postman_id": "8d3e2300-349c-485a-8b89-f538e124ea88",
		"name": "PayGate APIs",
		"description": "Collection để kiểm thử các API của dự án PayGate (Authentication, Merchant Admin, v.v.)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Authentication",
			"item": [
				{
					"name": "Register User",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"adminuser\",\n    \"email\": \"admin@paygate.com\",\n    \"password\": \"password123\",\n    \"fullName\": \"System Administrator\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/register",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"auth",
								"register"
							]
						},
						"description": "Đăng ký một tài khoản mới. Mặc định tài khoản được tạo sẽ có quyền USER. Để test các API Admin, bạn cần chạy câu lệnh SQL cập nhật role lên ADMIN."
					},
					"response": []
				},
				{
					"name": "Login User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.success && jsonData.data && jsonData.data.accessToken) {",
									"    pm.collectionVariables.set(\"jwtToken\", jsonData.data.accessToken);",
									"    console.log(\"Saved jwtToken to variables: \" + jsonData.data.accessToken);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"adminuser\",\n    \"password\": \"password123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/login",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"auth",
								"login"
							]
						},
						"description": "Đăng nhập với tài khoản vừa tạo để lấy JWT Token. Token sẽ tự động được trích xuất và lưu vào biến `jwtToken` để sử dụng ở các request sau."
					},
					"response": []
				}
			]
		},
		{
			"name": "2. Merchant Admin",
			"item": [
				{
					"name": "Create Merchant",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.success && jsonData.data && jsonData.data.id) {",
									"    pm.collectionVariables.set(\"merchantId\", jsonData.data.id);",
									"    console.log(\"Saved merchantId to variables: \" + jsonData.data.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{jwtToken}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"userId\": 1,\n    \"merchantName\": \"Shop TechMart\",\n    \"merchantCode\": \"TECHMART\",\n    \"webhookUrl\": \"https://techmart.com/webhook\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/admin/merchants",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"admin",
								"merchants"
							]
						},
						"description": "Đăng ký đối tác Merchant mới (Yêu cầu token của tài khoản ADMIN). Khi tạo thành công, hệ thống sẽ tự động tạo ví MERCHANT tương ứng thông qua AccountService."
					},
					"response": []
				},
				{
					"name": "Get All Merchants",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{jwtToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/admin/merchants?page=0&size=10&sortBy=createdAt&sortDir=DESC",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"admin",
								"merchants"
							],
							"query": [
								{
									"key": "page",
									"value": "0"
								},
								{
									"key": "size",
									"value": "10"
								},
								{
									"key": "sortBy",
									"value": "createdAt"
								},
								{
									"key": "sortDir",
									"value": "DESC"
								}
							]
						},
						"description": "Lấy danh sách các đối tác Merchant phân trang (Yêu cầu ADMIN)."
					},
					"response": []
				},
				{
					"name": "Get Merchant by ID",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{jwtToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/admin/merchants/{{merchantId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"admin",
								"merchants",
								"{{merchantId}}"
							]
						},
						"description": "Chi tiết thông tin của Merchant dựa trên merchantId đã lưu tự động."
					},
					"response": []
				},
				{
					"name": "Update Merchant",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{jwtToken}}",
									"type": "string"
								}
							]
						},
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"merchantName\": \"TechMart Super Store\",\n    \"webhookUrl\": \"https://new.techmart.com/webhook\",\n    \"active\": true\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/admin/merchants/{{merchantId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"admin",
								"merchants",
								"{{merchantId}}"
							]
						},
						"description": "Cập nhật thông tin chi tiết của đối tác Merchant."
					},
					"response": []
				}
			]
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080",
			"type": "string"
		},
		{
			"key": "jwtToken",
			"value": "",
			"type": "string"
		},
		{
			"key": "merchantId",
			"value": "",
			"type": "string"
		}
	]
}
