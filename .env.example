# Database Configuration
DB_NAME=training_db
DB_USER=postgres
DB_PASS=postgres

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ Configuration
MQ_HOST=localhost
MQ_PORT=5672
MQ_USER=guest
MQ_PASS=guest

# Gmail SMTP Configuration for Email Notifications
