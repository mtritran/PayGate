# ==============================================================================
# PayGate Environment Variables Template
# Copy this file to .env or set environment variables in your terminal/IDE
# DO NOT COMMIT YOUR REAL CREDENTIALS OR GMAIL APP PASSWORDS TO GITHUB!
# ==============================================================================

# Database Configuration
DB_NAME=training_db
DB_USER=postgres
DB_PASS=postgres

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ Configuration
MQ_HOST=localhost
MQ_PORT=5672
MQ_USER=guest
MQ_PASS=guest

# Gmail SMTP Configuration for Email Notifications
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_16_char_app_password

# OpenRouter AI Configuration (Free models: meta-llama/llama-3.3-70b-instruct:free, deepseek/deepseek-r1:free, stepfun/step-2-16k:free)
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key_here
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

